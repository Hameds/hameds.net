---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="خطای ۴۰۴" description="صفحه‌ای که دنبالش هستید وجود ندارد.">
  <article class="not-found">
    <span class="error-badge">خطا</span>
    <h1 class="hero-404">۴۰۴</h1>
    <p class="hero-quote">هر چیز که در جستن آنی، آنی</p>
    <p class="hero-back"><a href="/">برگرد به خانه</a></p>
  </article>
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    padding: 5em 0;
  }

  .error-badge {
    display: inline-block;
    font-size: 0.7em;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: var(--flexoki-yellow-900);
    background: var(--flexoki-yellow-100);
    border-radius: 100px;
    padding: 0.25em 0.85em;
    margin-bottom: 1.5em;
  }

  .hero-404 {
    font-size: calc(4em + 2vw);
    font-weight: 500;
    letter-spacing: -0.04em;
    line-height: 1;
    margin: 0 0 0.3em;
  }

  .hero-quote {
    font-size: calc(1em + 0.3vw);
    max-width: none;
    margin: 0 0 1.5em;
  }

  .hero-back {
    max-width: none;
  }

  .hero-back a {
    color: var(--color-tx-muted);
  }
</style>
