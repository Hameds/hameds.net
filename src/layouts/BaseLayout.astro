---
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
  section?: { label: string; url: string };
  socialTitle?: string;
  socialDescription?: string;
  socialImage?: string;
  socialUrl?: string;
  ogType?: "website" | "article";
}

const { title, description, section, socialTitle, socialDescription, socialImage, socialUrl, ogType = "article" } = Astro.props;
---

<!doctype html>
<html lang="fa" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? "یادداشت‌ها، ایده‌ها و روایت زیستن"} />
    <meta name="author" content="حامد" />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    {
      socialTitle && (
        <>
          <meta property="og:type" content={ogType} />
          <meta property="og:title" content={socialTitle} />
          {socialDescription && <meta property="og:description" content={socialDescription} />}
          {socialImage && <meta property="og:image" content={socialImage} />}
          {socialUrl && <meta property="og:url" content={socialUrl} />}
          <meta name="twitter:card" content="summary_large_image" />
          <meta name="twitter:title" content={socialTitle} />
          {socialDescription && <meta name="twitter:description" content={socialDescription} />}
          {socialImage && <meta name="twitter:image" content={socialImage} />}
        </>
      )
    }
    <title>{title}</title>
  </head>
  <body>
    <div id="progress-bar" role="progressbar" aria-hidden="true"></div>
    <script>
      if (
        localStorage.theme === "dark" ||
        (!("theme" in localStorage) &&
          window.matchMedia("(prefers-color-scheme: dark)").matches)
      ) {
        document.body.classList.add("theme-dark");
      }
    </script>

    <nav data-pagefind-ignore>
      <span class="site-name">
        <a href="/" class="plain">حامد</a>
        {section && <><span class="faint"> / </span><a href={section.url} class="muted plain">{section.label}</a></>}
      </span>
      <span class="nav-links">
        <a href="/about">درباره</a>
        <!-- <a href="/now" class="mh">اکنون</a> -->
      </span>
      <span class="search-wrapper">
        <input type="search" id="search-input" class="search-input" placeholder="جستجو" aria-label="جستجو">
        <span class="search-hint" aria-hidden="true">/</span>
        <button id="search-toggle" class="search-toggle" type="button" aria-label="باز کردن جستجو">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </button>
      </span>
      <button
        id="theme-toggle"
        class="theme-toggle"
        title="تغییر تم تاریک"
        aria-label="تغییر تم تاریک"
        type="button"
        role="switch"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 20 20"
          fill="currentColor"
        ><path
            fill-rule="evenodd"
            d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"
            clip-rule="evenodd"
          /></svg>
      </button>
    </nav>

    <div id="search-overlay" class="search-overlay" role="dialog" aria-modal="true" aria-label="جستجو">
      <div class="search-overlay-content">
        <div class="search-overlay-header">
          <span class="search-overlay-title">جستجو</span>
          <button class="search-close" aria-label="بستن">✕</button>
        </div>
        <input type="search" id="search-input-overlay" class="search-input-overlay" placeholder="عنوان یا کلمه کلیدی" aria-label="جستجو" autocomplete="off">
      </div>
    </div>

    <main data-pagefind-body>
      <slot />
      <hr />
    </main>

    <footer data-pagefind-ignore>
      <p><a href="/subscribe" class="muted">دنبال کردن</a></p>
      <p class="flex">
        <span>
          از طریق <a target="_blank" href="/feed.xml">RSS</a>،
          <a href="https://twitter.com/hamed" target="_blank" rel="noopener noreferrer">توییتر</a>
          و <a href="https://github.com/hameds" target="_blank" rel="noopener noreferrer">گیت‌هاب</a>
        </span>
        <span class="muted small license">استفاده از محتوا با لینک به نسخه اصلی مجاز است</span>
      </p>
    </footer>

    <script>
      const toggle = document.querySelector("#theme-toggle");
      const searchInput = document.querySelector("#search-input");
      const overlayInput = document.querySelector("#search-input-overlay");
      const searchToggle = document.querySelector("#search-toggle");
      const searchOverlay = document.querySelector("#search-overlay");
      const searchClose = document.querySelector(".search-close");

      function toggleTheme() {
        document.body.classList.toggle("theme-dark");
        updateThemeState();
      }

      function updateThemeState() {
        const isDark = document.body.classList.contains("theme-dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
        toggle.setAttribute("aria-checked", String(isDark));
      }

      function initTheme() {
        const isDark = document.body.classList.contains("theme-dark");
        toggle.setAttribute("aria-checked", String(isDark));
      }

      toggle.addEventListener("click", toggleTheme);

      function getActiveInput() {
        const isMobile = window.innerWidth <= 600;
        return isMobile ? overlayInput : searchInput;
      }

      function openSearch() {
        const input = getActiveInput();
        document.body.classList.add("search-open");
        input.focus();
      }

      function closeSearch() {
        document.body.classList.remove("search-open");
      }

      function handleSearchEnter(input) {
        if (input && input.value.trim()) {
          closeSearch();
          window.location.href = "/search?q=" + encodeURIComponent(input.value.trim());
        }
      }

      if (searchInput) {
        searchInput.addEventListener("keydown", (e) => {
          if (e.key === "Enter") handleSearchEnter(searchInput);
          if (e.key === "Escape") closeSearch();
        });
      }

      if (overlayInput) {
        overlayInput.addEventListener("keydown", (e) => {
          if (e.key === "Enter") handleSearchEnter(overlayInput);
          if (e.key === "Escape") closeSearch();
        });
      }

      if (searchToggle) {
        searchToggle.addEventListener("click", () => {
          if (document.body.classList.contains("search-open")) {
            closeSearch();
          } else {
            openSearch();
          }
        });
      }

      if (searchClose) {
        searchClose.addEventListener("click", closeSearch);
      }

      if (searchOverlay) {
        searchOverlay.addEventListener("click", (e) => {
          if (e.target === searchOverlay) closeSearch();
        });
      }

      window.addEventListener("keydown", (e) => {
        if (
          document.activeElement?.tagName === "INPUT" ||
          document.activeElement?.tagName === "TEXTAREA"
        )
          return;
        if ((e.key === "d" || e.key === "D") && !e.ctrlKey && !e.metaKey) {
          toggleTheme();
        }
        if (e.key === "/" && !e.ctrlKey && !e.metaKey) {
          e.preventDefault();
          openSearch();
        }
        if ((e.key === "s" || e.key === "S") && !e.ctrlKey && !e.metaKey) {
          e.preventDefault();
          openSearch();
        }
      });

      initTheme();

      const bar = document.querySelector("#progress-bar");
      if (bar) {
        window.addEventListener("scroll", () => {
          const max = document.documentElement.scrollHeight - window.innerHeight;
          bar.style.width = (window.scrollY / max) * 100 + "%";
        });
      }
    </script>
  </body>
</html>
